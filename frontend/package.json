{
  "name": "whalecum-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/tailwindcss/lib';const src=p+'/plugins/css/preflight.css';const dest=p+'/css/preflight.css';if(fs.existsSync(src)){fs.mkdirSync(p+'/css',{recursive:true});fs.copyFileSync(src,dest);}\""
  },
  "dependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^6.4.2",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@types/react": "^17.0.45",
    "@types/react-dom": "^17.0.17",
    "@vitejs/plugin-react": "^1.3.2",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "tailwindcss": "^2.2.19",
    "typescript": "^4.9.5",
    "vite": "~2.0.5"
  },
  "engines": {
    "node": ">=12.2.0"
  }
}
